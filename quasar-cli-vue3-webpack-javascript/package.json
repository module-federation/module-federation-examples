{
  "name": "quasar-cli-vue3-webpack-javascript",
  "private": true,
  "version": "0.0.0",
  "description": "Quasar Framework Example",
  "scripts": {
    "start": "concurrently --kill-others-on-fail \"pnpm --dir app-exposes exec -- env BROWSER=none quasar dev\" \"pnpm --dir app-general exec -- env BROWSER=none quasar dev\"",
    "test:e2e": "pnpm exec playwright test",
    "e2e:ci": "pnpm exec playwright test --reporter=list",
    "prestart": "node ../scripts/track-demo-run.js"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "concurrently": "8.2.2",
    "playwright": "1.58.2"
  }
}
